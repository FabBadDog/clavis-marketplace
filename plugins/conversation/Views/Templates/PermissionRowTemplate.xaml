<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:FabioSoft.Nucleus.Plugins.Conversation.ViewModels"
    xmlns:rendering="clr-namespace:FabioSoft.Clavis.Rendering;assembly=FabioSoft.Clavis.Rendering">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <DataTemplate DataType="{x:Type vm:PermissionViewModel}">
        <StackPanel Margin="0,4,0,4">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="RowSlide" Y="6" />
            </StackPanel.RenderTransform>
            <StackPanel.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="RowSlide" Storyboard.TargetProperty="Y"
                                             From="6" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </StackPanel.Triggers>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                        Visibility="{Binding ReasonText, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#x26A0; "
                           FontSize="9" FontFamily="{DynamicResource UiFont}"
                           Foreground="{DynamicResource WarnBrush}"
                           Opacity="0.85" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ReasonText}"
                           FontSize="9" FontFamily="{DynamicResource AgentFont}"
                           Foreground="{DynamicResource TextDimBrush}"
                           Opacity="0.75" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Left">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsResolved}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- The shared single-select control: ALLOW / DENY / ALWAYS ALLOW, the choice underlined.
                     Left/Right navigation and Enter are resolved by the host; a click commits directly. -->
                <rendering:SegmentedSelector DataContext="{Binding Selector}" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
