<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:FabioSoft.Nucleus.Plugins.Conversation.ViewModels"
    xmlns:rendering="clr-namespace:FabioSoft.Clavis.Rendering;assembly=FabioSoft.Clavis.Rendering">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibility" />
    <rendering:StatIconConverter x:Key="StatIcon" Size="10" />

    <DataTemplate DataType="{x:Type vm:TurnViewModel}">
        <Grid Margin="28,11,28,0" RenderTransformOrigin="0,0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="TurnSlide" Y="8" />
            </Grid.RenderTransform>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.25" FillBehavior="Stop">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="TurnSlide" Storyboard.TargetProperty="Y"
                                             From="8" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Rail column -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Width="20" Height="16"
                      Margin="0,1,0,0">

                    <!-- Breathing pixel -->
                    <Ellipse Width="6" Height="6"
                             Fill="{DynamicResource ClavisBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             RenderTransformOrigin="0.5,0.5">
                        <!-- Rail-charge ignite: when the turn goes active (a sent prompt powers up) the dot
                             flares - it pops in oversized with a brief glow and settles to its resting size.
                             Driven from the IsActive trigger below, not Loaded, so the flare plays when the
                             dot actually becomes visible. -->
                        <!-- Named so the Style trigger below can animate it: an unnamed Freezable in a
                             template is frozen (immutable) and cannot be animated from a Style. -->
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="DotIgniteScale" ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Visibility" Value="Hidden" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="BreatheStoryboard">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <!-- Start bright and delayed so the ignite pop below plays
                                                         on a fully-visible dot first, then settle into breathing. -->
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="1.0" To="0.1"
                                                        BeginTime="0:0:0.7"
                                                        Duration="0:0:0.6">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                            <!-- Ignite flare: a big oversized pop settling to resting size,
                                                 fired immediately on a fully-visible dot. -->
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     From="2.6" To="1" BeginTime="0:0:0.28" Duration="0:0:0.4">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     From="2.6" To="1" BeginTime="0:0:0.28" Duration="0:0:0.4">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="BreatheStoryboard" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Queued icon -->
                    <Ellipse Width="5" Height="5"
                             Fill="{DynamicResource ClavisBrush}"
                             Opacity="0.4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsQueued, Converter={StaticResource BooleanToVisibility}}" />

                    <!-- Done icon -->
                    <TextBlock Text="{Binding DoneIconText}"
                               FontWeight="Bold"
                               FontFamily="{DynamicResource UiFont}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               Visibility="{Binding ShowDoneIcon, Converter={StaticResource BooleanToVisibility}}">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="DoneIconScale" ScaleX="1" ScaleY="1" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                <Setter Property="Opacity" Value="0.9" />
                                <Setter Property="FontSize" Value="12" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSucceeded}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource ClavisBrush}" />
                                        <Setter Property="Opacity" Value="0.8" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAborted}" Value="True">
                                        <Setter Property="FontSize" Value="24" />
                                    </DataTrigger>
                                    <!-- Pop the completion glyph in when the turn finishes -->
                                    <DataTrigger Binding="{Binding ShowDoneIcon}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     From="0.6" To="1" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     From="0.6" To="1" Duration="0:0:0.12">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Timeline line -->
                <Rectangle Grid.Row="1"
                           Width="1.5"
                           Fill="{DynamicResource ClavisBrush}"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Stretch"
                           Margin="0,2,0,0"
                           RenderTransformOrigin="0.5,0">
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="RailScale" ScaleY="0" />
                    </Rectangle.RenderTransform>
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <!-- Rail charge: as a sent prompt's turn appears, the timeline rail draws in
                                     from the dot and flares to full brightness, then settles to its resting
                                     opacity - the new turn "powering up". -->
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="RailScale" Storyboard.TargetProperty="ScaleY"
                                                     From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.5" Duration="0:0:0.25" FillBehavior="Stop">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>

                <!-- Rail-charge streak: a bright pulse that races up the rail to the dot as the turn
                     powers up, then fades. The opacity mask makes it brightest at the top (the dot end)
                     and trail off below; it grows upward from the bottom of the rail. -->
                <Rectangle Grid.Row="1"
                           Width="3"
                           Fill="{DynamicResource ClavisBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Stretch"
                           Margin="0,2,0,0"
                           IsHitTestVisible="False"
                           RenderTransformOrigin="0.5,1">
                    <Rectangle.OpacityMask>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                            <GradientStop Color="#00000000" Offset="0" />
                            <GradientStop Color="#FF000000" Offset="0.65" />
                        </LinearGradientBrush>
                    </Rectangle.OpacityMask>
                    <!-- Named so the Style trigger can animate it (see the dot above). -->
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="StreakChargeScale" ScaleY="0" />
                    </Rectangle.RenderTransform>
                    <Rectangle.Style>
                        <Style TargetType="Rectangle">
                            <Style.Triggers>
                                <!-- Fire on activation (a sent prompt) so the streak races up only on a
                                     fresh send, not on every turn restored from history. -->
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="0" To="1" BeginTime="0:0:0.28" Duration="0:0:0.24">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0" BeginTime="0:0:0.46" Duration="0:0:0.28" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Rectangle.Style>
                </Rectangle>
            </Grid>

            <!-- Content column -->
            <StackPanel Grid.Column="2" Margin="10,18,0,0">
                <!-- Human prompt -->
                <TextBox Text="{Binding Prompt, Mode=OneWay}"
                         FontSize="12"
                         FontFamily="{DynamicResource HumanFont}"
                         Foreground="{DynamicResource TextBrightBrush}"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         CaretBrush="Transparent"
                         SelectionBrush="{DynamicResource ClavisBrush}"
                         IsTabStop="False"
                         Padding="0,0,0,8">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="InitTurn">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Child items -->
                <ItemsControl ItemsSource="{Binding Items}" Margin="0,0,0,6" />

                <!-- Rail whisper: the live session phase (thinking/compacting/retrying) projected onto the
                     active turn as PhaseWhisper, with an animated ellipsis whose three dots pulse in
                     sequence. The whole line hides on any non-working phase or once the turn ends. -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                            Visibility="{Binding ShowPhaseWhisper, Converter={StaticResource BooleanToVisibility}}">
                    <TextBlock Text="{Binding PhaseWhisper}"
                               FontSize="12"
                               FontFamily="{DynamicResource UiFont}"
                               Foreground="{DynamicResource ClavisBrush}"
                               Opacity="0.85" />
                    <TextBlock Text="." FontSize="12" FontFamily="{DynamicResource UiFont}"
                               Foreground="{DynamicResource ClavisBrush}" Opacity="0.85">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.15" To="0.85" Duration="0:0:0.5"
                                                         AutoReverse="True" RepeatBehavior="Forever"
                                                         BeginTime="0:0:0" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="." FontSize="12" FontFamily="{DynamicResource UiFont}"
                               Foreground="{DynamicResource ClavisBrush}" Opacity="0.85">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.15" To="0.85" Duration="0:0:0.5"
                                                         AutoReverse="True" RepeatBehavior="Forever"
                                                         BeginTime="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="." FontSize="12" FontFamily="{DynamicResource UiFont}"
                               Foreground="{DynamicResource ClavisBrush}" Opacity="0.85">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.15" To="0.85" Duration="0:0:0.5"
                                                         AutoReverse="True" RepeatBehavior="Forever"
                                                         BeginTime="0:0:0.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                </StackPanel>

                <!-- Status line: transient status messages only (e.g. "Retrying API call...", "DENIED").
                     The assistant's answer is no longer streamed here - completed blocks land as TextItems
                     above and reveal with the typewriter/line fall, so the partials are not shown live. -->
                <TextBlock Text="{Binding StatusText}"
                           FontSize="10"
                           FontWeight="Light"
                           FontFamily="{DynamicResource AgentFont}"
                           Foreground="{DynamicResource TextDimBrush}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Error text -->
                <TextBlock Text="{Binding ErrorText}"
                           FontSize="10"
                           FontWeight="Light"
                           FontFamily="{DynamicResource AgentFont}"
                           Foreground="{DynamicResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibility}}" />
            </StackPanel>

            <!-- Stats column: configurable micro-stats (geometric icon + value, dim), right-aligned to sit
                 just left of the rail. Built per turn from the StatusLine.statsColumn template against this
                 turn's turn.* values; the icon name renders as a geometric StatIcon. -->
            <ItemsControl Grid.Column="0" ItemsSource="{Binding Stats}"
                          VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,18,8,0"
                          Opacity="0.7">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2" HorizontalAlignment="Right">
                            <ContentControl Content="{Binding Icon, Converter={StaticResource StatIcon}}"
                                            Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Value}"
                                       FontSize="9" FontFamily="{DynamicResource MonoFont}"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsQueued}" Value="True">
                <Setter Property="FrameworkElement.Opacity" Value="0.55" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
