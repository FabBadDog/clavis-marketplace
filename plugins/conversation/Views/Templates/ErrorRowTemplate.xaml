<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:FabioSoft.Nucleus.Plugins.Conversation.ViewModels">

    <DataTemplate DataType="{x:Type vm:ErrorItemViewModel}">
        <TextBlock Text="{Binding Message}"
                   FontSize="10" FontWeight="Light"
                   FontFamily="{DynamicResource AgentFont}"
                   Foreground="{DynamicResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="0,2,0,2">
            <TextBlock.RenderTransform>
                <TranslateTransform x:Name="RowSlide" Y="6" />
            </TextBlock.RenderTransform>
            <TextBlock.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="RowSlide" Storyboard.TargetProperty="Y"
                                             From="6" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </TextBlock.Triggers>
        </TextBlock>
    </DataTemplate>

</ResourceDictionary>
