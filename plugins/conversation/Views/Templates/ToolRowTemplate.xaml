<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:FabioSoft.Nucleus.Plugins.Conversation.ViewModels">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <DataTemplate DataType="{x:Type vm:ToolItemViewModel}">
        <StackPanel Margin="0,2,0,8">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="RowSlide" Y="6" />
            </StackPanel.RenderTransform>
            <StackPanel.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="RowSlide" Storyboard.TargetProperty="Y"
                                             From="6" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </StackPanel.Triggers>

            <ToggleButton Style="{DynamicResource ChromeFreeToggle}"
                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                          IsEnabled="{Binding HasDetail}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Expand chevron: only when there is detail to reveal -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               FontSize="12" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontFamily="{DynamicResource UiFont}"
                               Visibility="{Binding HasDetail, Converter={StaticResource BoolToVis}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#x25B8;" />
                                <Setter Property="Opacity" Value="0.6" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Text" Value="&#x25BE;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center">
                        <Run Text="{Binding NameText, Mode=OneWay}"
                             FontSize="9" FontWeight="Medium"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontFamily="{DynamicResource UiFont}" />
                        <Run Text="  " FontSize="9" />
                        <Run Text="{Binding ArgumentsText, Mode=OneWay}"
                             FontSize="10.5"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontFamily="{DynamicResource MonoFont}" />
                        <Run Text="{Binding StatusText, Mode=OneWay}"
                             FontSize="9" FontWeight="SemiBold"
                             FontFamily="{DynamicResource UiFont}">
                            <Run.Style>
                                <Style TargetType="Run">
                                    <Setter Property="Foreground" Value="{DynamicResource ClavisBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDenied}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Run.Style>
                        </Run>
                    </TextBlock>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DurationText}"
                                   FontSize="9" FontFamily="{DynamicResource MonoFont}"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Opacity="0.5" Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ShowDuration, Converter={StaticResource BoolToVis}}" />

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ShowWarning, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="&#x26A0;"
                                       FontSize="10" Foreground="{DynamicResource WarnBrush}"
                                       Opacity="0.85" Margin="12,0,4,0"
                                       FontFamily="{DynamicResource UiFont}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WarningText}"
                                       FontSize="9" FontFamily="{DynamicResource AgentFont}"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Opacity="0.75" Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <ContentControl Content="{Binding ScopeBadge}"
                                            ContentTemplate="{DynamicResource BadgeTemplate}"
                                            VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ToggleButton>

            <!-- Expanded detail: full input + output, monospace, selectable, dimmed. -->
            <Border Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource ScopeBadgeBrush}"
                    Margin="14,4,0,2" Padding="8,6,8,6">
                <TextBox Text="{Binding DetailText, Mode=OneWay}"
                         Style="{DynamicResource ReadOnlyCodeTextBox}"
                         MaxHeight="320"
                         VerticalScrollBarVisibility="Auto" />
            </Border>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
