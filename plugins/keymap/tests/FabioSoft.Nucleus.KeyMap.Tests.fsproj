<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>FabioSoft.Nucleus.KeyMap.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <!-- Runtime-form test build: framework + modules come from the runtime Directory.Build.props
       (copied into this Tests project's output); only the local item under test is a ProjectReference. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.0.0" />
    <PackageReference Include="Faqt" Version="5.1.0" />
    <PackageReference Include="FsCheck.Xunit" Version="3.2.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\KeyMap.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="KeyGestureTests.fs" />
    <Compile Include="KeymapBindingsTests.fs" />
    <Compile Include="KeymapFileTests.fs" />
    <Compile Include="KeyMapPluginTests.fs" />
  </ItemGroup>
</Project>
