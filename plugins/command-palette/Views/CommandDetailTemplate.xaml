<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The detail pane for the highlighted command: name, a kind + source line, then the full, untruncated
         description. This is where long skill descriptions get room to breathe, so the list can stay dense. -->
    <DataTemplate x:Key="CommandDetailTemplate">
        <StackPanel>
            <TextBlock Text="{Binding DisplayName}"
                       FontSize="{DynamicResource HeadingFontSize}"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextBrightBrush}"
                       FontFamily="{DynamicResource UiFont}" />

            <StackPanel Orientation="Horizontal" Margin="0,7,0,12">
                <ContentControl Content="{Binding KindBadge}"
                                ContentTemplate="{DynamicResource BadgeTemplate}"
                                VerticalAlignment="Center" />
                <TextBlock Text="{Binding Source}"
                           Margin="12,0,0,0"
                           FontSize="{DynamicResource MetaFontSize}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontFamily="{DynamicResource MonoFont}" />
            </StackPanel>

            <TextBlock Text="{Binding Description}"
                       FontSize="{DynamicResource BodyFontSize}"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{DynamicResource AgentFont}" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
