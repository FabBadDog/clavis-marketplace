<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The master-list row: command name + its shortcut. Kind, source and the full description live in the
         detail pane (CommandDetailTemplate) for the highlighted row, so the list stays a dense, scannable
         column with no badges, boxes or column rules. The name brightens when the row is selected. -->
    <DataTemplate x:Key="CommandItemTemplate">
        <Grid Margin="0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="NameText"
                       Grid.Column="0"
                       Text="{Binding DisplayName}"
                       FontSize="{DynamicResource BodyFontSize}"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,12,0"
                       Foreground="{DynamicResource TextBrush}"
                       FontFamily="{DynamicResource UiFont}" />

            <TextBlock Grid.Column="1"
                       Text="{Binding Shortcut}"
                       FontSize="{DynamicResource MetaFontSize}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource HumanBrush}"
                       FontFamily="{DynamicResource MonoFont}" />
        </Grid>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=IsSelected}" Value="True">
                <Setter TargetName="NameText" Property="Foreground" Value="{DynamicResource TextBrightBrush}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

</ResourceDictionary>
