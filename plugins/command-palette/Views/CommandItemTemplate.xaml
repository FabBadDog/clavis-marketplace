<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- The master-list row: command name + its shortcut. Kind, source and the full description live in the
         detail pane (CommandDetailTemplate) for the highlighted row, so the list stays a clean, scannable
         column with no badges, boxes or column rules. The name uses the shared Selector.ItemTitle style and
         the row shares the panel picker's vertical rhythm (Margin 0,5), so the two popups read identically. -->
    <DataTemplate x:Key="CommandItemTemplate">
        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding DisplayName}"
                       Style="{DynamicResource Selector.ItemTitle}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,12,0" />

            <TextBlock Grid.Column="1"
                       Text="{Binding Shortcut}"
                       FontSize="{DynamicResource MetaFontSize}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource HumanBrush}"
                       FontFamily="{DynamicResource MonoFont}" />
        </Grid>
    </DataTemplate>

</ResourceDictionary>
