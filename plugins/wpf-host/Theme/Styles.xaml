<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:rendering="clr-namespace:FabioSoft.Clavis.Rendering;assembly=FabioSoft.Clavis.Rendering">

    <FontFamily x:Key="HumanFont">pack://application:,,,/WpfHost;component/Fonts/#Rajdhani</FontFamily>
    <FontFamily x:Key="AgentFont">pack://application:,,,/WpfHost;component/Fonts/#Inter</FontFamily>
    <FontFamily x:Key="MonoFont">pack://application:,,,/WpfHost;component/Fonts/#JetBrains Mono</FontFamily>
    <FontFamily x:Key="UiFont">pack://application:,,,/WpfHost;component/Fonts/#Rajdhani</FontFamily>

    <!-- The single source of truth for code-text size (monospace code blocks, inline code, tool/reasoning
         output). MarkdownPresenter reads this resource live and scales it by its FontScale, so this one
         value drives every code surface - change it here only. See design/CLAVIS-DESIGN-LANGUAGE.md "Typography". -->
    <sys:Double x:Key="CodeFontSize">10</sys:Double>

    <!-- Type-role sizes (the dual scale; see design/CLAVIS-DESIGN-LANGUAGE.md §4). PROSE (body / heading)
         stays generous, CHROME (label / mono / meta / micro) is compact. Kept in sync with the theme's
         `typography` block; the theme loader may override these from the active theme. Consumed by the
         Clavis.Text.* role styles below so a size change is one edit, not a hunt through views. -->
    <sys:Double x:Key="TitleFontSize">20</sys:Double>
    <sys:Double x:Key="HeadingFontSize">16</sys:Double>
    <sys:Double x:Key="BodyFontSize">14</sys:Double>
    <sys:Double x:Key="LabelFontSize">11</sys:Double>
    <sys:Double x:Key="MonoFontSize">9.45</sys:Double>
    <sys:Double x:Key="MetaFontSize">10</sys:Double>
    <sys:Double x:Key="MicroFontSize">9</sys:Double>

    <!-- These values are the CLAVIS "default" theme palette and are kept in sync with
         ~/.clavis/themes/default.yaml. At runtime the host's theme loader overrides every one of these keys
         from the active theme file (own keys on Application.Resources win over this merged dictionary), so
         these literals are the in-solution / no-theme fallback. See design/CLAVIS-DESIGN-LANGUAGE.md. -->
    <SolidColorBrush x:Key="BlackBrush" Color="#000000" />
    <SolidColorBrush x:Key="FrameBrush" Color="#5A5A66" />
    <SolidColorBrush x:Key="LineBrush" Color="#5A5A66" />
    <!-- A dimmer frame for black-on-black popups (the command palette / selector). The standard line
         (#5A5A66) reads as a hard box around an overlay; this darker grey lets the frame recede so the
         content carries the popup. Falls back here when a theme does not override it. -->
    <SolidColorBrush x:Key="PopupFrameBrush" Color="#3A3A44" />
    <SolidColorBrush x:Key="FaintBrush" Color="#0E0E14" />
    <SolidColorBrush x:Key="TextBrush" Color="#C8C8D0" />
    <SolidColorBrush x:Key="TextBrightBrush" Color="#E8E8EC" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#9A9AA4" />
    <SolidColorBrush x:Key="ClavisBrush" Color="#9FD5F0" />
    <SolidColorBrush x:Key="HumanBrush" Color="#ADA6F2" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#E47E7E" />
    <SolidColorBrush x:Key="WarnBrush" Color="#E4C47E" />
    <SolidColorBrush x:Key="InputBrush" Color="#ADA6F2" />
    <SolidColorBrush x:Key="EventErrorBrush" Color="#E47E7E" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="#9A9AA4" />

    <!-- Modern semantic keys (the names new code targets). Same palette, clearer intent. -->
    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#9FD5F0" />
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#ADA6F2" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#0E0E14" />
    <SolidColorBrush x:Key="BodyBrush" Color="#C8C8D0" />
    <SolidColorBrush x:Key="GreenBrush" Color="#7BD49B" />
    <SolidColorBrush x:Key="RedBrush" Color="#E47E7E" />
    <SolidColorBrush x:Key="YellowBrush" Color="#E4C47E" />

    <!-- Implementation tokens (derived greys; documented in default.yaml + CLAVIS-DESIGN-LANGUAGE.md §3). -->
    <SolidColorBrush x:Key="CodeBgBrush" Color="#14141C" />
    <SolidColorBrush x:Key="CodeBorderBrush" Color="#282834" />
    <SolidColorBrush x:Key="RailBrush" Color="#1B1B22" />
    <SolidColorBrush x:Key="RaisedBrush" Color="#36363F" />

    <!-- The seven type roles as shared TextBlock styles (CLAVIS-DESIGN-LANGUAGE.md §4 + §10). Each sets the
         role's voice (font), size (from the *FontSize keys above), weight and a sensible default foreground;
         a consumer overlays an accent / bright foreground locally. Views reference these by key instead of
         hardcoding a font/size, so the dual scale is enforced in one place. (Letter-spacing/tracking and
         uppercasing are applied by the consumer - WPF TextBlock has no first-class letter-spacing.) -->
    <Style x:Key="Clavis.Text.Title" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource HumanFont}" />
        <Setter Property="FontSize" Value="{DynamicResource TitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrightBrush}" />
    </Style>
    <Style x:Key="Clavis.Text.Heading" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource AgentFont}" />
        <Setter Property="FontSize" Value="{DynamicResource HeadingFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrightBrush}" />
    </Style>
    <Style x:Key="Clavis.Text.Body" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource AgentFont}" />
        <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource BodyBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="Clavis.Text.Label" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource HumanFont}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelFontSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    </Style>
    <Style x:Key="Clavis.Text.Mono" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="{DynamicResource MonoFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource BodyBrush}" />
    </Style>
    <Style x:Key="Clavis.Text.Meta" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="{DynamicResource MetaFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    </Style>
    <Style x:Key="Clavis.Text.Micro" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource HumanFont}" />
        <Setter Property="FontSize" Value="{DynamicResource MicroFontSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    </Style>

    <!-- Log-severity palette, shared by the events-panel filter and the log rows so a level reads the same
         colour in both places. Reuses the palette: dim trace, green debug, blue info, yellow warn, red error.
         ALL is shown in the plain bright text brush (nothing hidden, no severity). -->
    <SolidColorBrush x:Key="LevelTraceBrush" Color="#9A9AA4" />
    <SolidColorBrush x:Key="LevelDebugBrush" Color="#7BD49B" />
    <SolidColorBrush x:Key="LevelInfoBrush" Color="#9FD5F0" />
    <SolidColorBrush x:Key="LevelWarnBrush" Color="#E4C47E" />
    <SolidColorBrush x:Key="LevelErrorBrush" Color="#E47E7E" />
    <!-- Non-log bus messages: a distinct violet, apart from the severity hues (grey/green/blue/amber/red)
         so a plain message never reads as a DEBUG or INFO log. -->
    <SolidColorBrush x:Key="MessageBrush" Color="#C79BF0" />

    <!-- App-wide text-selection highlight for inputs: a soft gray band instead of WPF's default system
         blue, which clashes with the Clavis palette. This implicit style sets only the selection brush -
         no template, layout, or colours - so it is safe to apply to every TextBox; an input that wants a
         different selection (e.g. the read-only turn prompt's clavis tint) overrides it with a local value. -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="SelectionBrush" Value="{DynamicResource SecondaryBrush}" />
        <Setter Property="SelectionOpacity" Value="0.5" />
    </Style>

    <!-- Button press feedback: the pressed control's template border eases down to 90% while held and eases
         back to full size on release - a 250ms transition each way (the design's motion floor). Shared by the
         ActionButton family; each template names its scaled border "border" and owns a per-template
         (per-instance) ScaleTransform, so the animation only touches the pressed button, never a shared,
         frozen style-level transform. -->
    <Storyboard x:Key="ButtonPressDown">
        <DoubleAnimation Storyboard.TargetName="border"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="0.9" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="border"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="0.9" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>
    <Storyboard x:Key="ButtonPressUp">
        <DoubleAnimation Storyboard.TargetName="border"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                         To="1" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetName="border"
                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                         To="1" Duration="0:0:0.25">
            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Dark, square, minimal form inputs shared across the app (binding rows, filters, settings fields).
         Keyed (not implicit) so they only apply where referenced and never restyle every control in the app.
         Consumed in code via the clavis-controls factories (Input/ActionButton) and directly in XAML. -->
    <Style x:Key="InputTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ClavisBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2,6,2" />
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Focus cue: the input swaps its own gray border for the clavis accent on keyboard focus. The
             window's focus-ring overlay suppresses its ring for text inputs (FocusVisualController), so this
             border swap is the single cue - the gray border is replaced, never doubled by an outer ring. -->
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ActionButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,2,10,2" />
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelFontSize}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <!-- The scaled border carries a per-template (per-instance) ScaleTransform centred in
                         place, so the press storyboards dip this one button without touching a shared,
                         frozen style-level transform. Inherited shape; the triggers re-add the press feel. -->
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrightBrush}" />
                        </Trigger>
                        <!-- Press feedback: ease the border down to 90% while held, back to full on release. -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressDown}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressUp}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <!-- Keyboard focus owns its cue through the button's own border (gray -> clavis), matching the inputs,
             so the host's focus ring stays off and there is no second outline. Hover/press already recolour the
             border via the template's IsMouseOver trigger. Inherited by Primary/Danger (BasedOn). -->
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Primary action: clavis border + text at rest, a faint clavis fill on hover. The affirmative button
         (Install, Apply, Confirm). Same square chrome as ActionButton; colour carries the "primary" intent. -->
    <Style x:Key="ActionButtonPrimary" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Foreground" Value="{DynamicResource ClavisBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1A9FD5F0" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressDown}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressUp}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger action: neutral at rest, reveals red border + text + a faint red fill on hover. Destructive
         buttons (Uninstall, Delete). The hover is the warning, so the rest state stays calm. -->
    <Style x:Key="ActionButtonDanger" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                            <Setter TargetName="border" Property="Background" Value="#12E47E7E" />
                            <Setter Property="Foreground" Value="{DynamicResource RedBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressDown}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource ButtonPressUp}" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputComboBoxItem" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="6,3,6,3" />
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelFontSize}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="itemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="#22A8A8B0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputComboBox" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource InputComboBoxItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="Toggle"
                                      Focusable="False"
                                      ClickMode="Press"
                                      OverridesDefaultStyle="True"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                    <Border x:Name="toggleBorder"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1">
                                        <Path x:Name="arrow"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,7,0"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="{DynamicResource TextDimBrush}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- The combo shows focus by swapping its own border to the clavis accent
                                             (the focus-ring overlay suppresses its ring for combos, so this is the
                                             single cue, never a double outline); hover shows the same accent. -->
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="toggleBorder" Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="toggleBorder" Property="BorderBrush" Value="{DynamicResource ClavisBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="6,0,22,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               Focusable="False"
                               PopupAnimation="Slide"
                               IsOpen="{TemplateBinding IsDropDownOpen}">
                            <Border Background="{DynamicResource BlackBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="240">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThinScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="#33A8A8B0" SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border Background="#66A8A8B0" SnapsToDevicePixels="True" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="6" />
                <Setter Property="MinWidth" Value="6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True"
                                       Focusable="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinScrollBarThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Focusable="False"
                                                      IsTabStop="False"
                                                      Opacity="0"
                                                      Command="ScrollBar.PageDownCommand" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Focusable="False"
                                                      IsTabStop="False"
                                                      Opacity="0"
                                                      Command="ScrollBar.PageUpCommand" />
                                    </Track.DecreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- A flat, chrome-free toggle: a clickable header with no background, border, or padding so it reads as
         text, not a button (content before chrome). Shared by every expandable row (tool calls, reasoning
         blocks). HorizontalContentAlignment defaults to Stretch; a left-aligned header overrides it locally.
         A disabled toggle (nothing to expand) shows the default arrow cursor instead of the hand. -->
    <Style x:Key="ChromeFreeToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- A read-only, selectable monospace text view with no chrome: transparent, borderless, no caret, no tab
         stop, with the app's clavis selection. Shared by every inline code/output block (tool detail,
         reasoning text). Callers set per-use size limits (MaxHeight, scroll) and may override the font for a
         prose block. -->
    <Style x:Key="ReadOnlyCodeTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CaretBrush" Value="Transparent" />
        <Setter Property="SelectionBrush" Value="{DynamicResource ClavisBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="{DynamicResource CodeFontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    </Style>

    <!-- Badge building blocks. A badge is never assembled by hand: it is the BadgeTemplate below, hosted in
         a ContentControl whose Content is a BadgeViewModel (Text + AccentKey). These two styles and the
         converter are the template's pieces. The chip is outlined: a transparent fill with a 1px border in
         the accent colour and accent-coloured text, square corners (house rule). The BorderBrush is bound
         from the AccentKey in the template, since the accent is per-badge. -->
    <Style x:Key="Badge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6.3,1.8" />
    </Style>

    <!-- The badge label: Rajdhani micro, semibold, centred. The category colour arrives as a brush bound
         from the BadgeViewModel's AccentKey, overriding this secondary default. -->
    <Style x:Key="Badge.Label" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{DynamicResource UiFont}" />
        <!-- 10% below the Micro role (9): a badge-specific size so the chip reads a touch smaller without
             shrinking other micro-text. -->
        <Setter Property="FontSize" Value="8.1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
    </Style>

    <!-- Resolves a BadgeViewModel.AccentKey (a theme resource key) to its Brush for the label foreground. -->
    <rendering:KeyToBrushConverter x:Key="KeyToBrush" />

    <!-- THE badge. Every badge in the app is this one template, hosted in a ContentControl bound to a
         BadgeViewModel. A list consumer sets HorizontalContentAlignment=Stretch and stretches the host to
         its column, so a badge column shares one width; a lone badge sizes to its content. -->
    <DataTemplate x:Key="BadgeTemplate">
        <Border Style="{StaticResource Badge}"
                BorderBrush="{Binding AccentKey, Converter={StaticResource KeyToBrush}}">
            <TextBlock Style="{StaticResource Badge.Label}"
                       Text="{Binding Text}"
                       Foreground="{Binding AccentKey, Converter={StaticResource KeyToBrush}}" />
        </Border>
    </DataTemplate>

</ResourceDictionary>
