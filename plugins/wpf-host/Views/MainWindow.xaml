<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CLAVIS"
    Width="740"
    Height="640"
    MinWidth="400"
    MinHeight="260"
    Background="#000000"
    Foreground="#A8A8B0"
    BorderBrush="{DynamicResource FrameBrush}"
    BorderThickness="1"
    WindowStyle="None"
    AllowsTransparency="True"
    ResizeMode="CanResizeWithGrip">

    <!-- CaptionHeight="0": no OS caption band. The window content is scaled by a LayoutTransform
         (UiScaleFactor), which displaces WindowChrome's IsHitTestVisibleInChrome carve-outs from the visible
         chrome, so a caption would leave the close button unclickable. Dragging is driven manually from the
         title bar instead (WindowChromeViews.CreateTitleBar); the resize border is kept. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <ContentControl
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch" />

</Window>
