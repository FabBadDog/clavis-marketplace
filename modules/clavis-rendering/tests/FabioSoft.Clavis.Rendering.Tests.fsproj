<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>FabioSoft.Clavis.Rendering.Tests</RootNamespace>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <!-- Runtime-form test build: framework + modules come from the runtime Directory.Build.props
       (copied into this Tests project's output); only the local item under test is a ProjectReference. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.0.0" />
    <PackageReference Include="Faqt" Version="5.1.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\FabioSoft.Clavis.Rendering.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- PaceTests.fs is excluded: it tests the old `Pace` module / `WindowUsage` shape that the
         "Pace -> Limits" rename replaced. It needs rewriting against the new Limits API. -->
    <Compile Include="DockingModelTests.fs" />
    <Compile Include="SegmentedSelectorModelTests.fs" />
    <Compile Include="SelectorHistoryTests.fs" />
  </ItemGroup>
</Project>
